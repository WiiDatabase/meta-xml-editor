{
  "name": "meta-xml-editor",
  "version": "1.0.0",
  "description": "Editor and generator for Wii Homebrew meta.xml files",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "check": "biome check",
    "typecheck": "vue-tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@vitejs/plugin-vue": "6.0.7",
    "sass": "1.101.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vue-tsc": "3.3.5"
  },
  "dependencies": {
    "bootstrap": "5.3.8",
    "vue": "3.5.38"
  }
}
